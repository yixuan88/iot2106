[Unit]
Description=IoT Mesh Gateway
After=network.target bluetooth.target mosquitto.service
Wants=mosquitto.service bluetooth.service

[Service]
Type=simple
User=__USER__
WorkingDirectory=__PROJECT_DIR__
# Zone name is set in mqtt_bridge.py (_zone variable) — edit per gateway
ExecStart=__PROJECT_DIR__/venv/bin/python3 -m gateway.main --bluetooth --mqtt
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
